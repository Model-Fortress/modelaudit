{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>promptfoo/renovate-config"],
  "packageRules": [
    {
      "description": "Keep NumPy 1.x constraints on Python 3.10 markers in pyproject.toml.",
      "matchFileNames": ["pyproject.toml"],
      "matchManagers": ["pep621"],
      "matchPackageNames": ["numpy"],
      "matchCurrentValue": "/<2\\.0/",
      "allowedVersions": "<2.0"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "vulnerabilityFixStrategy": "lowest"
  }
}
